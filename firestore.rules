rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /workflows/{workflow} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "osama.ellafi@gmail.com";
    }
    match /site_stats/{stat} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "osama.ellafi@gmail.com";
    }
    match /contact_messages/{message} {
      allow read, write: if request.auth != null && request.auth.token.email == "osama.ellafi@gmail.com";
      allow create: if true; // anyone can send a message
    }
  }
}
